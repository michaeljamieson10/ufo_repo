# Source binaries — too big for git. Mirror them with scripts/download.py.
releases/*/pdfs/
releases/*/images/
releases/*/videos/
releases/*/download.log
releases/*/run.out
*.part
.DS_Store
__pycache__/
.venv/

# Build / runtime logs (regenerable, not source).
logs/

# Vector / graph DB stores — regenerable from the committed JSONLs via
# scripts/make_dbs.sh, OR downloadable as a tarball from GitHub Releases.
pipelines/store/
pipelines/graphrag/data/falkordb/
pipelines/graphrag/data/frames/

# Pipeline JSONL artifacts ARE committed — they encode the expensive
# LLM extractions (OCR, captions, entities, communities). Anyone with
# the repo can rebuild Chroma + FalkorDB in ~5 min instead of ~2 hr.
# Explicit allowlist beats trying to *.jsonl-ignore by accident.
!pipelines/data/
!pipelines/data/*.jsonl
!pipelines/graphrag/data/
!pipelines/graphrag/data/*.jsonl
.env
